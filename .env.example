# Copy this file to .env and replace local placeholders where needed.

# Local database
POSTGRES_DB=n11_clone
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

DB_URL=jdbc:postgresql://localhost:5433/n11_clone
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Local frontend and cookie policy
SERVER_PORT=8081
CORS_ALLOWED_ORIGIN=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
COOKIE_SECURE=false

# Authentication
# Use a private value of at least 32 characters. Never commit the real secret.
JWT_SECRET=replace-with-a-private-local-secret-at-least-32-characters
JWT_ACCESS_EXPIRATION_MS=1200000
JWT_REFRESH_EXPIRATION_DAYS=14
EMAIL_VERIFICATION_EXPIRATION_HOURS=24
PASSWORD_RESET_EXPIRATION_MINUTES=60

# Gmail SMTP email delivery
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-address@gmail.com
# Use a Google App Password, never your regular Google account password.
MAIL_PASSWORD=replace-with-your-16-character-google-app-password
MAIL_FROM=your-address@gmail.com
